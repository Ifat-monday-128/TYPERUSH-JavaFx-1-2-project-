<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.GaussianBlur?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #0D1117;"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.TYPERUSH.MenuController">

    <StackPane layoutX="900.0" layoutY="-80.0" prefHeight="450.0" prefWidth="450.0"
               style="-fx-background-color: #00E5FF; -fx-background-radius: 500; -fx-opacity: 0.10;">
        <effect><GaussianBlur radius="130.0"/></effect>
    </StackPane>
    <StackPane layoutX="-100.0" layoutY="350.0" prefHeight="380.0" prefWidth="380.0"
               style="-fx-background-color: #0066FF; -fx-background-radius: 500; -fx-opacity: 0.10;">
        <effect><GaussianBlur radius="120.0"/></effect>
    </StackPane>
    <StackPane layoutX="500.0" layoutY="500.0" prefHeight="300.0" prefWidth="300.0"
               style="-fx-background-color: #00E5FF; -fx-background-radius: 500; -fx-opacity: 0.06;">
        <effect><GaussianBlur radius="100.0"/></effect>
    </StackPane>

    <VBox alignment="CENTER" spacing="16.0"
          AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <!-- TITLE -->
        <VBox alignment="CENTER" spacing="8.0">
            <Label text="ABOUT US" textFill="#ffffff">
                <font><Font name="System Bold" size="58.0"/></font>
                <effect><DropShadow color="#00e5ff60" radius="20.0" spread="0.1"/></effect>
            </Label>
            <StackPane prefHeight="3.0" prefWidth="120.0"
                       style="-fx-background-color: #00E5FF; -fx-background-radius: 4;">
                <effect><DropShadow color="#00e5ff" radius="10.0" spread="0.6"/></effect>
            </StackPane>
            <Label text="SUPERVISOR &amp; DEVELOPERS" textFill="#8b949e">
                <font><Font name="System" size="18.0"/></font>
                <VBox.margin><Insets top="6.0"/></VBox.margin>
            </Label>
        </VBox>

        <!-- THREE CARDS ROW: Supervisor + Developer 1 + Developer 2 -->
        <HBox alignment="CENTER" spacing="35.0">

            <!-- SUPERVISOR CARD -->
            <VBox alignment="CENTER" prefWidth="360.0" spacing="0.0"
                  style="-fx-background-color: #161b22; -fx-border-color: #e2b714;
                         -fx-border-width: 1; -fx-border-radius: 16; -fx-background-radius: 16;">
                <effect><DropShadow color="#e2b71425" radius="30.0" spread="0.05"/></effect>
                <StackPane prefHeight="4.0" prefWidth="360.0"
                           style="-fx-background-color: #e2b714; -fx-background-radius: 16 16 0 0;"/>
                <VBox alignment="CENTER" spacing="14.0">
                    <VBox.margin><Insets top="25.0" bottom="30.0" left="25.0" right="25.0"/></VBox.margin>
                    <Label text="SUPERVISOR" textFill="#e2b714">
                        <font><Font name="System Bold" size="11.0"/></font>
                    </Label>
                    <Label text="Kowshic Roy" textFill="#ffffff" wrapText="true">
                        <font><Font name="System Bold" size="22.0"/></font>
                    </Label>
                    <Separator style="-fx-background-color: #21262d;" prefWidth="280.0"/>
                    <VBox spacing="10.0" alignment="CENTER_LEFT">
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label text="🏫" style="-fx-font-size: 16px;"/>
                            <VBox spacing="2.0">
                                <Label text="DESIGNATION" textFill="#8b949e">
                                    <font><Font name="System" size="11.0"/></font>
                                </Label>
                                <Label text="Lecturer" textFill="#e2b714">
                                    <font><Font name="System Bold" size="16.0"/></font>
                                </Label>
                            </VBox>
                        </HBox>
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label text="📚" style="-fx-font-size: 16px;"/>
                            <VBox spacing="2.0">
                                <Label text="DEPARTMENT" textFill="#8b949e">
                                    <font><Font name="System" size="11.0"/></font>
                                </Label>
                                <Label text="CSE, BUET" textFill="#ffffff">
                                    <font><Font name="System Bold" size="16.0"/></font>
                                </Label>
                            </VBox>
                        </HBox>
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label text="📧" style="-fx-font-size: 16px;"/>
                            <VBox spacing="2.0">
                                <Label text="EMAIL" textFill="#8b949e">
                                    <font><Font name="System" size="11.0"/></font>
                                </Label>
                                <Label text="kowshic@teacher.cse.buet.ac.bd"
                                       textFill="#00E5FF" wrapText="true">
                                    <font><Font name="System" size="13.0"/></font>
                                </Label>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>

            <!-- DEVELOPER 1 CARD -->
            <VBox alignment="CENTER" prefWidth="360.0" spacing="0.0"
                  style="-fx-background-color: #161b22; -fx-border-color: #00E5FF;
                         -fx-border-width: 1; -fx-border-radius: 16; -fx-background-radius: 16;">
                <effect><DropShadow color="#00e5ff25" radius="30.0" spread="0.05"/></effect>
                <StackPane prefHeight="4.0" prefWidth="360.0"
                           style="-fx-background-color: #00E5FF; -fx-background-radius: 16 16 0 0;"/>
                <VBox alignment="CENTER" spacing="14.0">
                    <VBox.margin><Insets top="25.0" bottom="30.0" left="25.0" right="25.0"/></VBox.margin>
                    <Label text="DEVELOPER" textFill="#00E5FF">
                        <font><Font name="System Bold" size="11.0"/></font>
                    </Label>
                    <Label text="Mahtab Hasan Ifat" textFill="#ffffff" wrapText="true">
                        <font><Font name="System Bold" size="22.0"/></font>
                    </Label>
                    <Separator style="-fx-background-color: #21262d;" prefWidth="280.0"/>
                    <VBox spacing="10.0" alignment="CENTER_LEFT">
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label text="🎓" style="-fx-font-size: 16px;"/>
                            <VBox spacing="2.0">
                                <Label text="ROLL NO" textFill="#8b949e">
                                    <font><Font name="System" size="11.0"/></font>
                                </Label>
                                <Label text="2405128" textFill="#00E5FF">
                                    <font><Font name="System Bold" size="16.0"/></font>
                                </Label>
                            </VBox>
                        </HBox>
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label text="📚" style="-fx-font-size: 16px;"/>
                            <VBox spacing="2.0">
                                <Label text="DEPARTMENT" textFill="#8b949e">
                                    <font><Font name="System" size="11.0"/></font>
                                </Label>
                                <Label text="CSE 1-2, BUET" textFill="#ffffff">
                                    <font><Font name="System Bold" size="16.0"/></font>
                                </Label>
                            </VBox>
                        </HBox>
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label text="🔗" style="-fx-font-size: 16px;"/>
                            <VBox spacing="2.0">
                                <Label text="CONTACT" textFill="#8b949e">
                                    <font><Font name="System" size="11.0"/></font>
                                </Label>
                                <Button text="Facebook Profile"
                                        onAction="#openIfatFacebook"
                                        style="-fx-background-color: #1877F2; -fx-text-fill: white;
                                               -fx-font-weight: bold; -fx-background-radius: 6;
                                               -fx-cursor: hand; -fx-padding: 5 14;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>

            <!-- DEVELOPER 2 CARD -->
            <VBox alignment="CENTER" prefWidth="360.0" spacing="0.0"
                  style="-fx-background-color: #161b22; -fx-border-color: #00E5FF;
                         -fx-border-width: 1; -fx-border-radius: 16; -fx-background-radius: 16;">
                <effect><DropShadow color="#00e5ff25" radius="30.0" spread="0.05"/></effect>
                <StackPane prefHeight="4.0" prefWidth="360.0"
                           style="-fx-background-color: #00E5FF; -fx-background-radius: 16 16 0 0;"/>
                <VBox alignment="CENTER" spacing="14.0">
                    <VBox.margin><Insets top="25.0" bottom="30.0" left="25.0" right="25.0"/></VBox.margin>
                    <Label text="DEVELOPER" textFill="#00E5FF">
                        <font><Font name="System Bold" size="11.0"/></font>
                    </Label>
                    <Label text="Mahmodur Rahman Sajib" textFill="#ffffff" wrapText="true">
                        <font><Font name="System Bold" size="22.0"/></font>
                    </Label>
                    <Separator style="-fx-background-color: #21262d;" prefWidth="280.0"/>
                    <VBox spacing="10.0" alignment="CENTER_LEFT">
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label text="🎓" style="-fx-font-size: 16px;"/>
                            <VBox spacing="2.0">
                                <Label text="ROLL NO" textFill="#8b949e">
                                    <font><Font name="System" size="11.0"/></font>
                                </Label>
                                <Label text="2405129" textFill="#00E5FF">
                                    <font><Font name="System Bold" size="16.0"/></font>
                                </Label>
                            </VBox>
                        </HBox>
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label text="📚" style="-fx-font-size: 16px;"/>
                            <VBox spacing="2.0">
                                <Label text="DEPARTMENT" textFill="#8b949e">
                                    <font><Font name="System" size="11.0"/></font>
                                </Label>
                                <Label text="CSE 1-2, BUET" textFill="#ffffff">
                                    <font><Font name="System Bold" size="16.0"/></font>
                                </Label>
                            </VBox>
                        </HBox>
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label text="🔗" style="-fx-font-size: 16px;"/>
                            <VBox spacing="2.0">
                                <Label text="CONTACT" textFill="#8b949e">
                                    <font><Font name="System" size="11.0"/></font>
                                </Label>
                                <Button text="Facebook Profile"
                                        onAction="#openSajibFacebook"
                                        style="-fx-background-color: #1877F2; -fx-text-fill: white;
                                               -fx-font-weight: bold; -fx-background-radius: 6;
                                               -fx-cursor: hand; -fx-padding: 5 14;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>

        </HBox>

        <!-- PROJECT OVERVIEW -->
        <VBox maxWidth="1115.0" spacing="12.0"
              style="-fx-background-color: #161b22; -fx-border-color: #00E5FF;
                     -fx-border-width: 1; -fx-border-radius: 16;
                     -fx-background-radius: 16; -fx-padding: 26;">
            <effect><DropShadow color="#00e5ff25" radius="30.0" spread="0.05"/></effect>
            <Label text="PROJECT OVERVIEW" textFill="#8b949e">
                <font><Font name="System Bold" size="11.0"/></font>
            </Label>
            <Separator style="-fx-background-color: #21262d;"/>
            <Label wrapText="true" textFill="#cccccc"
                   text="TYPERUSH is a competitive typing game developed as a project of CSE 108, designed to make improving typing speed enjoyable.">
                <font><Font name="System" size="14.0"/></font>
            </Label>

            <Label wrapText="true" textFill="#cccccc"
                   text="Train in Tutor Mode, race the clock in Racing Mode, or go head-to-head with a friend in Multiplayer Mode over a local network. Three modes, one goal — make you a better typist.">
                <font><Font name="System" size="14.0"/></font>
            </Label>
            <Label wrapText="true" textFill="#cccccc"
                   text="Every session is saved. Track your WPM, accuracy, and progress through personal history graphs and a 365-day activity map. A rotating tip system also keeps your technique sharp between rounds, covering everything from home row discipline to posture.">
                <font><Font name="System" size="14.0"/></font>
            </Label>
            <Label wrapText="true" textFill="#cccccc"
                   text="The practice passages pull from real events close to Bangladeshi students — because context makes the grind worth it.">
                <font><Font name="System" size="14.0"/></font>
            </Label>
            <Label wrapText="true" textFill="#e2b714"
                   text="Type more. Type better. Type Rush."
                   style="-fx-font-style: italic; -fx-font-weight: bold;">
                <font><Font name="System Bold" size="14.0"/></font>
            </Label>
            <Button text="View on GitHub"
                    onAction="#openGithubRepo"
                    style="-fx-background-color: #24292e; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 6;
                           -fx-border-color: #444c56; -fx-border-width: 1;
                           -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 7 18;">
                <font><Font name="System Bold" size="13.0"/></font>
            </Button>
        </VBox>

        <!-- BACK BUTTON -->
        <VBox alignment="CENTER" spacing="8.0">
            <Button text="← BACK TO MENU" onAction="#backToMenu"
                    style="-fx-background-color: transparent; -fx-border-color: #444c56;
                           -fx-border-width: 1; -fx-border-radius: 6;
                           -fx-text-fill: #8b949e; -fx-cursor: hand; -fx-padding: 8 20;">
                <font><Font name="System" size="14.0"/></font>
            </Button>
        </VBox>

    </VBox>

</AnchorPane>