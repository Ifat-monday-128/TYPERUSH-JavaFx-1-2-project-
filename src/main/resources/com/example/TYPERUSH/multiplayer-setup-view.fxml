<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="30.0" styleClass="game-root"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.TYPERUSH.MultiplayerController">
    <padding>
        <Insets top="20" bottom="20" left="60" right="60"/>
    </padding>

   <HBox spacing="40" alignment="CENTER">

        <VBox alignment="CENTER" spacing="15" prefWidth="360" prefHeight="200"
              style="-fx-padding: 25;
                     -fx-border-color: #00E5FF;
                     -fx-border-width: 2;
                     -fx-border-radius: 12;
                     -fx-background-color: rgba(0,229,255,0.05);
                     -fx-background-radius: 12;">
            <Label text="✏  YOUR RACING NAME"
                   style="-fx-text-fill: #00E5FF; -fx-font-weight: bold; -fx-font-size: 17;"/>
            <TextField fx:id="nameField"
                       promptText="Enter your name..."
                       alignment="CENTER"
                       style="-fx-background-color: #161B22;
                              -fx-text-fill: #00E5FF;
                              -fx-font-size: 20;
                              -fx-font-weight: bold;
                              -fx-border-color: #30363D;
                              -fx-border-radius: 10;
                              -fx-pref-height: 55;
                              -fx-pref-width: 300;"/>
            <Label text="Your opponent will see this name."
                   wrapText="true" textAlignment="CENTER"
                   style="-fx-text-fill: #444C56; -fx-font-size: 12;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="15" prefWidth="360" prefHeight="200"
              style="-fx-padding: 25;
                     -fx-border-color: #E2B714;
                     -fx-border-width: 2;
                     -fx-border-radius: 12;
                     -fx-background-color: rgba(226,183,20,0.05);
                     -fx-background-radius: 12;">
            <Label text="🌐  YOUR IP ADDRESS"
                   style="-fx-text-fill: #E2B714; -fx-font-weight: bold; -fx-font-size: 17;"/>
            <Label fx:id="statusLabel" text="Loading IP..."
                   style="-fx-text-fill: #E2B714; -fx-font-weight: bold; -fx-font-size: 26;"/>
            <Label text="Share this with your opponent."
                   wrapText="true" textAlignment="CENTER"
                   style="-fx-text-fill: #444C56; -fx-font-size: 12;"/>
        </VBox>

        <VBox alignment="CENTER_LEFT" spacing="10" prefWidth="360" prefHeight="200"
              style="-fx-padding: 25;
             -fx-border-color: #E2B714;
             -fx-border-width: 2;
             -fx-border-radius: 12;
             -fx-background-color: rgba(226,183,20,0.05);
             -fx-background-radius: 12;">
            <Label text="⚠  STRICT RACING RULES"
                   style="-fx-text-fill: #E2B714; -fx-font-weight: bold; -fx-font-size: 17;"/>
            <Label wrapText="true"
                   text="• Both players must be on the same network.&#10;• Host starts the server first, then joiner connects.&#10;• Leaving mid-race counts as a forfeit.&#10;• First to finish the paragraph wins."
                   style="-fx-text-fill: #E2B714;
                  -fx-font-size: 13;
                  -fx-line-spacing: 6;
                  -fx-font-weight: bold;"/>
        </VBox>

    </HBox>

    <HBox spacing="60" alignment="CENTER">

        <VBox spacing="20" alignment="CENTER" prefWidth="550" prefHeight="260"
              style="-fx-padding: 30;
                     -fx-border-color: #00E5FF;
                     -fx-border-width: 2;
                     -fx-border-radius: 12;
                     -fx-background-color: rgba(0,229,255,0.05);
                     -fx-background-radius: 12;">
            <Label text="HOST A MATCH"
                   style="-fx-text-fill: #00E5FF; -fx-font-weight: bold; -fx-font-size: 32;"/>
            <Label text="Create a server and wait for your opponent to join your network."
                   wrapText="true" textAlignment="CENTER"
                   style="-fx-text-fill: #8B949E; -fx-font-size: 15;"/>
            <Button mnemonicParsing="false" onAction="#onHostClicked"
                    prefHeight="60.0" prefWidth="280.0"
                    text="START SERVER"
                    style="-fx-background-color: #00E5FF;
                           -fx-text-fill: black;
                           -fx-font-weight: bold;
                           -fx-font-size: 18;
                           -fx-background-radius: 10;
                           -fx-cursor: hand;"/>
            <Label text="PORT: 5555"
                   style="-fx-text-fill: #444C56; -fx-font-weight: bold; -fx-font-size: 16;"/>
        </VBox>

        <VBox spacing="15" alignment="CENTER" prefWidth="550" prefHeight="260"
              style="-fx-padding: 30;
                     -fx-border-color: #E2B714;
                     -fx-border-width: 2;
                     -fx-border-radius: 12;
                     -fx-background-color: rgba(226,183,20,0.05);
                     -fx-background-radius: 12;">
            <Label text="JOIN A MATCH"
                   style="-fx-text-fill: #E2B714; -fx-font-weight: bold; -fx-font-size: 32;"/>
            <VBox spacing="10" alignment="CENTER">
                <Label text="TARGET IP ADDRESS"
                       style="-fx-text-fill: #8B949E; -fx-font-size: 14; -fx-font-weight: bold;"/>
                <TextField fx:id="ipInputField"
                           promptText="e.g. 192.168.1.10"
                           alignment="CENTER"
                           style="-fx-background-color: #161B22;
                                  -fx-text-fill: #E2B714;
                                  -fx-font-size: 22;
                                  -fx-font-weight: bold;
                                  -fx-border-color: #30363D;
                                  -fx-border-radius: 8;
                                  -fx-pref-height: 60;
                                  -fx-pref-width: 320;"/>
            </VBox>
            <Button mnemonicParsing="false" onAction="#onJoinClicked"
                    prefHeight="60.0" prefWidth="280.0"
                    text="JOIN RACE"
                    style="-fx-background-color: #E2B714;
                           -fx-text-fill: black;
                           -fx-font-weight: bold;
                           -fx-font-size: 18;
                           -fx-background-radius: 10;
                           -fx-cursor: hand;"/>
        </VBox>

    </HBox>

    <VBox alignment="CENTER">
        <Button mnemonicParsing="false" onAction="#backToMenu"
                text="← ABORT TO MENU"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #E2B714;
                       -fx-border-color: #E2B714;
                       -fx-border-radius: 10;
                       -fx-font-size: 16;
                       -fx-padding: 8 20;
                       -fx-cursor: hand;"/>
    </VBox>

</VBox>