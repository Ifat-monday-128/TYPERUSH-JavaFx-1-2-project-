<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.TextFlow?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.TYPERUSH.MultiplayerGameController">

    <!-- MAIN GAME SCREEN -->
    <VBox alignment="TOP_CENTER" spacing="15.0" styleClass="game-root">

        <HBox alignment="CENTER" spacing="50.0">
            <Label fx:id="myNameLabel" styleClass="stat-text" text="YOU" textFill="#00e5ff"/>
            <Label fx:id="wpmLabel" styleClass="stat-text" text="WPM: 0" />
            <Label fx:id="accuracyLabel" styleClass="stat-text" text="Accuracy: 100%" />
            <Label fx:id="timerLabel"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #00E5FF;"
                   text="2:30" />
        </HBox>

        <Pane prefHeight="100.0" prefWidth="1200.0" styleClass="race-track"
              style="-fx-border-color: #00e5ff;">
            <Label layoutX="1150.0" layoutY="15.0" style="-fx-font-size: 50px;" text="🏁" />
            <StackPane fx:id="myCarContainer" layoutX="40.0" layoutY="20.0" styleClass="car-glow">
                <ImageView fitHeight="60.0" fitWidth="100.0" preserveRatio="true">
                    <image><Image url="@car.png" /></image>
                </ImageView>
            </StackPane>
        </Pane>

        <HBox alignment="CENTER" spacing="50.0">
            <Label fx:id="opponentStatusLabel" styleClass="stat-text" text="OPPONENT" textFill="#e2b714"/>
            <Label fx:id="opponentWpmLabel" styleClass="stat-text" text="WPM: 0" textFill="#aaaaaa" />
            <Label fx:id="opponentAccLabel" styleClass="stat-text" text="Accuracy: 100%" textFill="#aaaaaa" />
        </HBox>

        <Pane prefHeight="100.0" prefWidth="1200.0" styleClass="race-track">
            <Label layoutX="1150.0" layoutY="15.0" style="-fx-font-size: 50px;" text="🏁" />
            <StackPane fx:id="opponentCarContainer" layoutX="40.0" layoutY="20.0">
                <ImageView fitHeight="60.0" fitWidth="100.0" preserveRatio="true">
                    <image><Image url="@car.png" /></image>
                </ImageView>
            </StackPane>
        </Pane>

        <TextFlow fx:id="targetTextFlow" maxWidth="1050" minHeight="120"
                  style="-fx-background-color: rgba(0,0,0,0.5); -fx-padding: 20; -fx-background-radius: 15;"
                  textAlignment="CENTER" />
        <Label fx:id="countdownLabel" text=""
               style="-fx-font-size: 90px; -fx-font-weight: bold; -fx-text-fill: #00E5FF;"
               visible="false"/>
        <TextField fx:id="inputField" maxWidth="850.0"
                   onKeyReleased="#handleTyping"
                   prefHeight="60.0" styleClass="typing-input" />

        <Button onAction="#leaveMatch" styleClass="btn-backtomenu" text="LEAVE MATCH" />

    </VBox>

    <StackPane fx:id="freezeWarning" visible="false"
               mouseTransparent="true"
               style="-fx-background-color: transparent;">
        <VBox alignment="CENTER" spacing="6"
              style="-fx-background-color: rgba(255,50,50,0.92);
                     -fx-background-radius: 10;
                     -fx-padding: 10 20 10 20;
                     -fx-max-width: 420;
                     -fx-max-height: 70;"
              VBox.vgrow="NEVER">
            <Label text="&#9888; Input Frozen!"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="10 wrong characters! Use Backspace to fix errors."
                   style="-fx-font-size: 12px; -fx-text-fill: #ffe0e0;"/>
        </VBox>
    </StackPane>

    <!-- RESULT OVERLAY — hidden until race ends -->
    <StackPane fx:id="resultOverlay" visible="false"
               style="-fx-background-color: rgba(0,0,0,0.88);">

        <VBox alignment="CENTER" spacing="30"
              style="-fx-padding: 60;
                     -fx-max-width: 700;
                     -fx-max-height: 500;
                     -fx-background-color: rgba(255,255,255,0.04);
                     -fx-background-radius: 20;
                     -fx-border-color: #00E5FF;
                     -fx-border-width: 2;
                     -fx-border-radius: 20;">

            <Label fx:id="resultIcon" text="🏆"
                   style="-fx-font-size: 90px;"/>

            <Label fx:id="resultTitle" text="YOU WON!"
                   style="-fx-font-size: 52px; -fx-font-weight: bold; -fx-text-fill: #00E5FF;"/>

            <Label fx:id="resultMessage" text="Congratulations! You finished first!"
                   wrapText="true" textAlignment="CENTER"
                   style="-fx-font-size: 20px; -fx-text-fill: #8B949E;"/>

            <HBox alignment="CENTER" spacing="80"
                  style="-fx-padding: 20;
                         -fx-background-color: rgba(255,255,255,0.05);
                         -fx-background-radius: 12;">
                <VBox alignment="CENTER" spacing="5">
                    <Label fx:id="resultWpm" text="0"
                           style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #E2B714;"/>
                    <Label text="WPM"
                           style="-fx-font-size: 14px; -fx-text-fill: #8B949E; -fx-font-weight: bold;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="5">
                    <Label fx:id="resultAcc" text="0%"
                           style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #E2B714;"/>
                    <Label text="ACCURACY"
                           style="-fx-font-size: 14px; -fx-text-fill: #8B949E; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <Button onAction="#leaveMatch" text="← BACK TO MENU"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #E2B714;
                           -fx-border-color: #E2B714;
                           -fx-border-radius: 10;
                           -fx-font-size: 16;
                           -fx-font-weight: bold;
                           -fx-padding: 12 30;
                           -fx-cursor: hand;"/>
        </VBox>
    </StackPane>

</StackPane>